{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@utils/*": ["utils/*"],
      "@fixtures/*": ["fixtures/*"],
      "@pages/*": ["pages/*"]
    }
  },
  "include": ["tests/**/*", "utils/**/*", "fixtures/**/*", "pages/**/*", "playwright.config.ts"]
}
